{
  "package": {
    "productName": "mdex",
    "version": "6.0.0"
  },
  "build": {
    "beforeDevCommand": "npm --prefix src/ui run dev",
    "beforeBuildCommand": "npm --prefix src/ui run build",
    "devPath": "http://localhost:3000",
    "distDir": "../src/ui/out"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.mdex.singularity",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      }
    },
    "windows": [
      {
        "title": "MDex Singularity Omni-v6",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
